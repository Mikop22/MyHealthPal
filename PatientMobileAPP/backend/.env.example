# AWS SageMaker endpoint for MedGemma
SAGEMAKER_ENDPOINT_NAME=medgemma-endpoint
AWS_REGION=us-east-1

# AWS credentials are read from ~/.aws/credentials or these env vars:
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

MAX_IMAGE_SIZE_MB=10
MEDGEMMA_MAX_NEW_TOKENS=2048

# Supabase for label storage
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DoctorAPP backend URL for appointment-prep integration
DOCTORAPP_BASE_URL=http://localhost:8000
# DOCTORAPP_TIMEOUT=30

# CORS: comma-separated origins, or * to allow all (easiest for demo / hackathon)
# Leave unset to allow any localhost origin by default.
# ALLOWED_ORIGINS=*
